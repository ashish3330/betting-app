# Binaries (anchor patterns to repo root with leading slash so we don't match
# cmd/<service>-service/ directories). The bin/ directory is the canonical
# build output for scripts/start-all.sh; everything in this list is what
# `go build ./cmd/<svc>` would drop in the repo root if invoked without -o.
bin/
/api-test
/admin-service
/auth-service
/casino-service
/fraud-service
/gateway
/hierarchy-service
/matching-engine
/notification-service
/odds-service
/payment-service
/reporting-service
/risk-service
/wallet-service
# Legacy monolith binary names — kept so an older clone with stale
# checkouts doesn't accidentally commit them.
/server
/mockserver
*.exe
*.out

# Dependencies
frontend/node_modules/
vendor/

# Environment
.env
.env.local
frontend/.env.local

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Build outputs
coverage.out
coverage.html
docs/swagger/
frontend/.next/
frontend/tsconfig.tsbuildinfo

# Keys
keys/
*.pem

# Logs
*.log

# OS
Thumbs.db
