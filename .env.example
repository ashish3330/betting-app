# =============================================================
# Lotus Exchange -- Environment Configuration
# Copy to .env and fill in production values
#
# SECURITY: This file contains PLACEHOLDERS only. Do NOT commit
# real secrets to the repo. For production, source these from a
# secrets manager (Vault, AWS Secrets Manager, GCP Secret Manager,
# sealed-secrets) — never from a checked-in .env file.
# =============================================================

# ----- Server --------------------------------------------------
HTTP_PORT=8080
WS_PORT=8081
ENVIRONMENT=development        # development | staging | production
LOG_LEVEL=info                 # debug | info | warn | error
SHUTDOWN_TIMEOUT=15s

# ----- PostgreSQL -----------------------------------------------
# DEV DEFAULTS — rotate before any non-local deploy.
POSTGRES_DB=bettingdb
POSTGRES_USER=lotus
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
POSTGRES_PORT=5432
# Production MUST use sslmode=require (or verify-full with a CA bundle).
# sslmode=disable is acceptable ONLY for local docker-compose dev.
DATABASE_URL=postgres://lotus:CHANGE_ME_BEFORE_DEPLOY@localhost:5432/bettingdb?sslmode=disable&search_path=betting,auth,public
DB_MAX_OPEN_CONNS=100          # production sizing — tune to Postgres max_connections
DB_MAX_IDLE_CONNS=50
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# ----- Redis ----------------------------------------------------
REDIS_URL=localhost:6379
REDIS_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
REDIS_PORT=6379
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s

# ----- NATS -----------------------------------------------------
NATS_URL=nats://localhost:4222
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_MAX_RECONNECTS=60
NATS_RECONNECT_WAIT=2s

# ----- ClickHouse -----------------------------------------------
CLICKHOUSE_URL=tcp://localhost:9000
CLICKHOUSE_DB=lotus_analytics
CLICKHOUSE_USER=lotus
CLICKHOUSE_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# ----- JWT / Auth ------------------------------------------------
# Generate ED25519 keys: openssl genpkey -algorithm ed25519 -out private.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
# Fallback HMAC secret (used only when key files are absent).
# In production, ALWAYS use the EdDSA key files — HMAC is symmetric
# and any service with the secret can mint tokens.
JWT_SECRET=CHANGE_ME_BEFORE_DEPLOY_USE_KEYFILES_INSTEAD
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h

# ----- Encryption envelope ------------------------------------
# 32+ char shared secret used by AES-256-GCM payload envelope.
# Production MUST source this from a secrets manager.
ENCRYPTION_SECRET=CHANGE_ME_BEFORE_DEPLOY_min_32_characters_required

# ----- Seed handler -----------------------------------------------
# Header secret required by POST /api/v1/seed. Used only in dev / CI
# to populate test users. Disable or rotate in production.
SEED_SECRET=CHANGE_ME_BEFORE_DEPLOY
SEED_SUPERADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
SEED_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
SEED_MASTER_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
SEED_AGENT_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
SEED_PLAYER_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# ----- CORS & Security -----------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
TRUSTED_PROXIES=127.0.0.1,::1
SECURE_COOKIES=false           # set true behind TLS in production

# ----- Odds Provider --------------------------------------------
# "mock" or "entity_sports"
ODDS_PROVIDER=mock
ENTITY_SPORTS_API_KEY=
ENTITY_SPORTS_URL=https://rest.entitysport.com/v2
MOCK_VOLATILITY=0.05
MOCK_UPDATE_INTERVAL=2s

# ----- Rate Limiting --------------------------------------------
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# ----- Payments -------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
CRYPTO_WEBHOOK_KEY=

# ----- Cloudflare -----------------------------------------------
CLOUDFLARE_TOKEN=
CLOUDFLARE_ZONE_ID=

# ----- Frontend -------------------------------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8081

# ----- Monitoring -----------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_BEFORE_DEPLOY
METRICS_ENDPOINT=/metrics
HEALTH_ENDPOINT=/healthz
PPROF_ENABLED=false            # enable Go pprof in development
