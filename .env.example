# =============================================================
# Lotus Exchange -- Environment Configuration
# Copy to .env and fill in production values
# =============================================================

# ----- Server --------------------------------------------------
HTTP_PORT=8080
WS_PORT=8081
ENVIRONMENT=development        # development | staging | production
LOG_LEVEL=info                 # debug | info | warn | error
SHUTDOWN_TIMEOUT=15s

# ----- PostgreSQL -----------------------------------------------
POSTGRES_DB=bettingdb
POSTGRES_USER=lotus
POSTGRES_PASSWORD=L0tus!Xchg2026
POSTGRES_PORT=5432
DATABASE_URL=postgres://lotus:L0tus!Xchg2026@localhost:5432/bettingdb?sslmode=disable&search_path=betting,auth,public
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# ----- Redis ----------------------------------------------------
REDIS_URL=localhost:6379
REDIS_PASSWORD=R3dis!Lotus2026
REDIS_PORT=6379
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s

# ----- NATS -----------------------------------------------------
NATS_URL=nats://localhost:4222
NATS_PORT=4222
NATS_MONITOR_PORT=8222
NATS_MAX_RECONNECTS=60
NATS_RECONNECT_WAIT=2s

# ----- ClickHouse -----------------------------------------------
CLICKHOUSE_URL=tcp://localhost:9000
CLICKHOUSE_DB=lotus_analytics
CLICKHOUSE_USER=lotus
CLICKHOUSE_PASSWORD=Cl1ck!Lotus2026
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# ----- JWT / Auth ------------------------------------------------
# Generate ED25519 keys: openssl genpkey -algorithm ed25519 -out private.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
# Fallback HMAC secret (used only when key files are absent)
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=168h

# ----- CORS & Security -----------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
TRUSTED_PROXIES=127.0.0.1,::1
SECURE_COOKIES=false           # set true behind TLS in production

# ----- Odds Provider --------------------------------------------
# "mock" or "entity_sports"
ODDS_PROVIDER=mock
ENTITY_SPORTS_API_KEY=
ENTITY_SPORTS_URL=https://rest.entitysport.com/v2
MOCK_VOLATILITY=0.05
MOCK_UPDATE_INTERVAL=2s

# ----- Rate Limiting --------------------------------------------
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# ----- Payments -------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=
CRYPTO_WEBHOOK_KEY=

# ----- Cloudflare -----------------------------------------------
CLOUDFLARE_TOKEN=
CLOUDFLARE_ZONE_ID=

# ----- Frontend -------------------------------------------------
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8081

# ----- Monitoring -----------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=Gr4fana!Lotus2026
METRICS_ENDPOINT=/metrics
HEALTH_ENDPOINT=/healthz
PPROF_ENABLED=false            # enable Go pprof in development
